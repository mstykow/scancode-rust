# Test fixtures should always be reviewable and trackable, even when they use
# names like dist/, node_modules/, *.log, or *.exe.
!testdata/
!testdata/**

# Keep transient SQLite journal files created while exercising test fixtures ignored.
testdata/**/*.sqlite-shm
testdata/**/*.sqlite-wal
