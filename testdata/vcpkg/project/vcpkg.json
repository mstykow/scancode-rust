{
  "name": "sample-project",
  "version-string": "1.0.0",
  "description": "A sample vcpkg project manifest",
  "homepage": "https://example.com/sample-project",
  "license": "MIT",
  "builtin-baseline": "3426db05b996481ca31e95fff3734cf23e0f51bc",
  "dependencies": [
    "fmt",
    {
      "name": "cpprestsdk",
      "default-features": false,
      "features": ["websockets"],
      "host": true,
      "platform": "windows",
      "version>=": "2.10.18#1"
    },
    {
      "name": "zlib",
      "version>=": "1.3.1#2"
    }
  ],
  "overrides": [
    {
      "name": "zlib",
      "version": "1.3.1#2"
    }
  ],
  "supports": "windows | linux",
  "configuration": {
    "overlay-ports": ["./ports"],
    "overlay-triplets": ["./triplets"]
  }
}
