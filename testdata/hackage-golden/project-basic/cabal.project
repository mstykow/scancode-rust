packages:
  ./*.cabal
  app/*.cabal
optional-packages:
  vendor/*.cabal
extra-packages:
  lens-5.2.1
  text ==1.2.5.0
import: ./shared.project

source-repository-package
  type: git
  location: https://github.com/commercialhaskell/pantry.git
  tag: 0123456789abcdef
  subdir:
    pantry
    pantry-test

allow-newer: true
constraints:
  aeson >= 2.0
index-state: 2024-01-01T00:00:00Z
