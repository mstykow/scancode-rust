{
  "name": "scancode-rust",
  "version": "0.1.0",
  "private": true,
  "description": "High-performance Rust tool for detecting licenses, copyrights, and package metadata",
  "scripts": {
    "format": "prettier --write \"**/*.{yml,yaml,json,md}\"",
    "format:check": "prettier --check \"**/*.{yml,yaml,json,md}\""
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "devDependencies": {
    "prettier": "3.8.1"
  }
}
